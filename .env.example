# HubSpot Forms Submission API credentials.
# Copy this file to .env.local and fill in values from the client.

# Numeric Hub ID. Visible in any HubSpot URL: app.hubspot.com/contacts/<PORTAL_ID>/...
HUBSPOT_PORTAL_ID=

# Form GUID (UUID). Marketing > Forms > [open form] > Share/Embed shows formId.
HUBSPOT_FORM_GUID=

# Datacenter region: "na1" (US, default) or "eu1" (EU).
HUBSPOT_REGION=na1
