# HubSpot Forms Submission API credentials.
# Copy this file to .env.local and fill in values from the client.

# Numeric Hub ID. Visible in any HubSpot URL: app.hubspot.com/contacts/<PORTAL_ID>/...
HUBSPOT_PORTAL_ID=

# Form GUID (UUID). Marketing > Forms > [open form] > Share/Embed shows formId.
HUBSPOT_FORM_GUID=

# Datacenter region. All North America portals (na1, na2, na3, …) share the
# same Forms Submission endpoint (api.hsforms.com) — only "eu1" switches hosts
# (api-eu1.hsforms.com). For NA portals this value is documentation; the code
# only branches on the literal string "eu1".
HUBSPOT_REGION=na1
